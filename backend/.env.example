# .env.example

# Flask Environment (Development / Production)
FLASK_ENV=development
FLASK_APP=run.py

# Security
# Run `python -c "import secrets; print(secrets.token_hex(24))"` to generate these
SECRET_KEY=your_super_secret_key_here
JWT_SECRET_KEY=your_super_jwt_secret_here

# Database
# Example MySQL: mysql+pymysql://user:password@host:port/dbname
DATABASE_URL=mysql+pymysql://root:rootpassword@db:3306/saas_billing

# Third-Party Integrations
RAZORPAY_KEY_ID=rzp_test_yourKeyId
RAZORPAY_KEY_SECRET=your_razorpay_secret_here
SENDGRID_API_KEY=SG.your_sendgrid_api_key_here
